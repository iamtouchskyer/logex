# GitHub OAuth App credentials — required. Obtain via /api/auth/setup flow.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# HMAC key for signing the session JWT. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=

# Vercel Blob read/write token for share link storage. Set automatically when
# a Blob store is connected in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

# Optional: pin the public host if the Vercel alias differs from the canonical
# deployment URL. Defaults to logex-io.vercel.app when unset.
# PUBLIC_HOST=logex-io.vercel.app
