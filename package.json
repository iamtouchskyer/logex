{
  "name": "@touchskyer/logex",
  "version": "0.1.0",
  "type": "module",
  "description": "Write blog-style session papers from a Claude Code session JSONL",
  "license": "MIT",
  "author": "touchskyer",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamtouchskyer/logex"
  },
  "bin": {
    "logex": "dist/bin/logex.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "hooks/",
    "skills/",
    ".claude-plugin/",
    "smithery.yaml",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run build:cli",
    "build:cli": "tsc -p tsconfig.cli.json && node scripts/postbuild-cli.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --grep-invert a11y",
    "test:a11y": "playwright test --grep a11y",
    "extract": "npx tsx src/pipeline/extract.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "commander": "^14.0.3",
    "nanoid": "^5.1.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
